---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { formatCount, getAdjacentModels, getDefaultVariant, getModelBySlug, getVariantByKey, listModelSlugs } from "@/lib/catalog";

export function getStaticPaths() {
  return listModelSlugs().map((slug) => ({ params: { slug } }));
}

const model = getModelBySlug(Astro.params.slug ?? "");
const requestedVariantKey = Astro.url.searchParams.get("v");
const selectedVariant = getVariantByKey(model, requestedVariantKey);
const defaultVariant = getDefaultVariant(model);
const { prev, next } = getAdjacentModels(model.slug);
const meta = [
  ["Ops", model.n_ops ?? "unknown"],
  ["Category", model.category],
  ["Recurrent", model.is_recurrent === null ? "unknown" : model.is_recurrent ? "yes" : "no"],
  ["Parameters", formatCount(model.param_count)],
  ["Stable ID", model.stable_id],
  ["Graph hash", model.graph_shape_hash || "unknown"],
  ["Forward validation", model.forward_validated ? `${model.input_tier} input` : "not validated"],
  ["License", model.source_license],
];
---

<BaseLayout title={model.display_name} description={`${model.display_name} rendered TorchLens architecture diagram.`} ogImage={defaultVariant.thumb.url}>
  <section class="shell py-8">
    <div class="mb-6 flex flex-wrap items-center justify-between gap-4">
      <div>
        <a href="/models" class="text-sm" style="color: var(--secondary);">Back to models</a>
        <h1 class="mt-2 text-4xl font-semibold">{model.display_name}</h1>
      </div>
      <div class="flex flex-wrap gap-2">
        <span class="chip">{model.category}</span>
        <span class="chip">{model.family_normalized || "family unknown"}</span>
        <span class="chip">{model.forward_validated ? `validated: ${model.input_tier}` : "validation pending"}</span>
      </div>
    </div>

    <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_360px]">
      <section class="panel overflow-hidden">
        <div class="flex flex-wrap items-center justify-between gap-2 border-b p-3" style="border-color: var(--border);">
          <div>
            <h2 class="text-sm font-semibold">Architecture diagram</h2>
            <p class="text-xs" style="color: var(--secondary);">Rendered with TorchLens / Graphviz</p>
          </div>
          <div class="flex flex-wrap gap-2">
            <button class="button" type="button" data-panzoom="zoom-in">+</button>
            <button class="button" type="button" data-panzoom="zoom-out">-</button>
            <button class="button" type="button" data-panzoom="reset">Fit</button>
            <a class="button" href={selectedVariant.svg.url}>Open SVG</a>
          </div>
        </div>
        <div class="flex flex-wrap gap-2 border-b p-3" style="border-color: var(--border);" role="tablist" aria-label="Diagram variants">
          {model.variants.map((variant) => (
            <a
              class:list={["button", variant.key === selectedVariant.key && "primary"]}
              href={`/models/${model.slug}?v=${encodeURIComponent(variant.key)}`}
              role="tab"
              aria-selected={variant.key === selectedVariant.key ? "true" : "false"}
            >
              {variant.label}
            </a>
          ))}
        </div>
        {selectedVariant.monster ? (
          <div class="diagram-bg grid min-h-[520px] place-items-center p-6 text-center">
            <div class="space-y-4">
              <img src={selectedVariant.thumb.url} alt={`${model.display_name} monster graph thumbnail`} class="mx-auto max-h-80 rounded border object-contain" style="border-color: var(--border);" />
              <p style="color: var(--secondary);">Monster graph detected. Inline rendering is lazy-skipped for page weight; OpenSeadragon tiling is a TODO for the Tier-B atlas.</p>
              <a class="button primary" href={selectedVariant.svg.url}>Open full SVG</a>
            </div>
          </div>
        ) : (
          <div id="diagram-stage" class="diagram-bg h-[70vh] min-h-[520px] overflow-hidden p-4" tabindex="0" aria-label={`${model.display_name} pan and zoom diagram`}>
            <div id="diagram-panzoom" class="inline-block origin-top-left">
              <img src={selectedVariant.svg.url} alt={`${model.display_name} architecture diagram`} class="max-w-none select-none" draggable="false" />
            </div>
          </div>
        )}
      </section>

      <aside class="space-y-4">
        <section class="panel p-4">
          <h2 class="mb-3 text-lg font-semibold">Metrics</h2>
          <dl class="grid grid-cols-2 gap-x-4 gap-y-3 text-sm">
            {meta.map(([label, value]) => (
              <>
                <dt style="color: var(--secondary);">{label}</dt>
                <dd class="min-w-0 overflow-hidden text-ellipsis">{value}</dd>
              </>
            ))}
          </dl>
        </section>
        <section class="panel space-y-3 p-4 text-sm">
          <h2 class="text-lg font-semibold">Downloads</h2>
          <div class="flex flex-wrap gap-2">
            <a class="button primary" href={selectedVariant.svg.url}>SVG</a>
            {selectedVariant.pdf ? <a class="button" href={selectedVariant.pdf.url}>PDF</a> : <span class="button" aria-disabled="true">PDF pending</span>}
            {model.tlspec ? <a class="button" href={model.tlspec.url}>tlspec</a> : <span class="button" aria-disabled="true">tlspec pending</span>}
          </div>
          <p style="color: var(--secondary);">
            Source zoo and license are placeholders until validation metadata lands: {model.source_zoo}, {model.source_license}.
          </p>
        </section>
        <section class="panel space-y-2 p-4 text-sm" style="color: var(--secondary);">
          <p>Rendered with TorchLens v{model.torchlens_version}; renderer {model.renderer_version}.</p>
          <p>{model.source_url ? <a href={model.source_url}>Source</a> : "Source URL pending"}{model.paper_url ? <> · <a href={model.paper_url}>Paper</a></> : null}</p>
        </section>
        <nav class="grid grid-cols-2 gap-3">
          <a class="button" href={prev ? `/models/${prev.slug}` : "#"} aria-disabled={prev ? "false" : "true"}>Previous</a>
          <a class="button" href={next ? `/models/${next.slug}` : "#"} aria-disabled={next ? "false" : "true"}>Next</a>
        </nav>
      </aside>
    </div>
  </section>
  {!selectedVariant.monster && (
    <script>
      import Panzoom from "@panzoom/panzoom";

      const elem = document.getElementById("diagram-panzoom");
      const stage = document.getElementById("diagram-stage");
      if (elem && stage) {
        const panzoom = Panzoom(elem, { maxScale: 8, minScale: 0.2, contain: "outside" });
        stage.addEventListener("wheel", panzoom.zoomWithWheel);
        document.querySelector('[data-panzoom="zoom-in"]')?.addEventListener("click", () => panzoom.zoomIn());
        document.querySelector('[data-panzoom="zoom-out"]')?.addEventListener("click", () => panzoom.zoomOut());
        document.querySelector('[data-panzoom="reset"]')?.addEventListener("click", () => panzoom.reset());
      }
    </script>
  )}
</BaseLayout>
