---
import CopyCode from "@/components/CopyCode.astro";
import FunnelStrip from "@/components/FunnelStrip.astro";
import ModelCard from "@/components/ModelCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getAllModels, getFeaturedModels, getFunnel } from "@/lib/catalog";

const funnel = getFunnel();
const featured = getFeaturedModels(6);
const domains = [...new Set(getAllModels().map((model) => model.domain))].sort();
---

<BaseLayout title="TorchLens Model Menagerie" ogImage={featured[0]?.assets.thumb.url}>
  <section class="shell grid gap-8 py-14 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
    <div class="space-y-6">
      <p class="mono text-sm" style="color: var(--accent);">Synthetic fixture scaffold</p>
      <h1 class="max-w-3xl text-5xl font-semibold leading-tight md:text-6xl">TorchLens Model Menagerie</h1>
      <p class="max-w-2xl text-lg leading-8" style="color: var(--secondary);">
        A static observatory for neural-net architecture diagrams, rich metadata, and downloadable exports. This local build uses generated synthetic data only.
      </p>
      <CopyCode code="tl.trace(model, x); log.draw()" />
      <div class="flex flex-wrap gap-3">
        <a class="button primary" href="/models">Explore models</a>
        <a class="button" href="/dataset">Download fixture</a>
        <a class="button" href="https://github.com/johnmarktaylor91/torchlens" rel="noreferrer">GitHub</a>
        <a class="button" href="https://pypi.org/project/torchlens/" rel="noreferrer">PyPI</a>
      </div>
    </div>
    <div class="diagram-bg panel overflow-hidden p-3">
      <img src={featured[0]?.assets.thumb.url} alt="Featured synthetic architecture diagram" class="aspect-video w-full rounded object-cover" />
    </div>
  </section>

  <section class="shell space-y-4 pb-12">
    <h2 class="text-2xl font-semibold">Featured diagrams</h2>
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {featured.map((model) => <ModelCard model={model} />)}
    </div>
  </section>

  <section class="shell space-y-4 pb-12">
    <h2 class="text-2xl font-semibold">Browse by domain</h2>
    <div class="flex flex-wrap gap-2">
      {domains.map((domain) => <a class="chip" href={`/models?domain=${encodeURIComponent(domain)}`}>{domain}</a>)}
    </div>
  </section>

  <section class="shell space-y-4 pb-12">
    <h2 class="text-2xl font-semibold">Verification funnel</h2>
    <FunnelStrip funnel={funnel} />
  </section>

  <section class="shell pb-16">
    <div class="panel flex flex-wrap items-center justify-between gap-4 p-5">
      <div>
        <h2 class="text-xl font-semibold">Trace your own model</h2>
        <p class="mt-1 text-sm" style="color: var(--secondary);">The real export will replace this fixture at the same data seam.</p>
      </div>
      <a class="button primary" href="/about">Read methodology</a>
    </div>
  </section>
</BaseLayout>
