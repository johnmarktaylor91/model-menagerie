---
import FunnelStrip from "@/components/FunnelStrip.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getFunnel, getManifest } from "@/lib/catalog";

const funnel = getFunnel();
const manifest = getManifest();
const fields = [
  ["stable_id", "Stable identifier retained across exports"],
  ["slug", "URL-safe model identifier"],
  ["display_name", "Human-facing model name"],
  ["family_normalized", "Normalized model family"],
  ["domain", "Primary model domain"],
  ["input_tier", "real, wrapper, or none"],
  ["assets", "Local fixture asset references and checksums"],
];
---

<BaseLayout title="Dataset" description="Synthetic TorchLens fixture dataset download page.">
  <section class="shell space-y-8 py-10">
    <div>
      <p class="mono text-sm" style="color: var(--accent);">Serious dataset stub</p>
      <h1 class="mt-2 text-4xl font-semibold">Synthetic export v{manifest.export_version}</h1>
      <p class="mt-3 max-w-3xl leading-7" style="color: var(--secondary);">This page exercises the eventual dataset landing page against generated fixture data. Real catalog data swaps in by replacing fixture/export/v1.</p>
    </div>
    <FunnelStrip funnel={funnel} />
    <div class="flex flex-wrap gap-3">
      <a class="button primary" href="/fixture/export/v1/catalog.csv">Download CSV</a>
      <a class="button primary" href="/fixture/export/v1/models.jsonl">Download JSONL</a>
      <a class="button" href="/fixture/export/v1/export_manifest.json">Manifest</a>
    </div>
    <section>
      <h2 class="mb-3 text-2xl font-semibold">Schema</h2>
      <div class="panel overflow-x-auto">
        <table class="w-full min-w-[620px] text-left text-sm">
          <thead><tr><th class="p-3">Field</th><th class="p-3">Description</th></tr></thead>
          <tbody>{fields.map(([field, description]) => <tr class="border-t" style="border-color: var(--border);"><td class="mono p-3">{field}</td><td class="p-3" style="color: var(--secondary);">{description}</td></tr>)}</tbody>
        </table>
      </div>
    </section>
    <section class="grid gap-4 lg:grid-cols-2">
      <div class="panel p-4">
        <h2 class="mb-3 text-xl font-semibold">Load in 3 lines</h2>
        <pre class="overflow-x-auto text-sm"><code>import pandas as pd
models = pd.read_json("fixture/export/v1/models.jsonl", lines=True)
print(models[["slug", "domain", "input_tier"]].head())</code></pre>
      </div>
      <div class="panel p-4">
        <h2 class="mb-3 text-xl font-semibold">DuckDB-Wasm console</h2>
        <p style="color: var(--secondary);">Coming soon. The scaffold keeps this as a labeled placeholder.</p>
      </div>
    </section>
    <section class="panel p-4">
      <h2 class="mb-2 text-xl font-semibold">Citation and license</h2>
      <p class="mono text-sm">TorchLens Model Menagerie synthetic scaffold, export v{manifest.export_version}, schema {manifest.schema_version}.</p>
      <p class="mt-2 text-sm" style="color: var(--secondary);">Fixture metadata is synthetic and intended for scaffold validation. Dataset page copy assumes CC BY 4.0 for the eventual public export.</p>
    </section>
  </section>
</BaseLayout>
