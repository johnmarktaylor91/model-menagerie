---
import type { Funnel } from "@/lib/catalog";

interface Props {
  funnel: Funnel;
}

const { funnel } = Astro.props;
const items = [
  ["Cataloged", funnel.cataloged],
  ["Build verified", funnel.build_verified],
  ["Real forward", funnel.forward_validated_real],
  ["Wrapper forward", funnel.forward_validated_wrapper],
  ["Rendered", funnel.rendered],
  ["Quarantined", funnel.quarantined],
  ["Deferred", funnel.deferred],
];
---

<section class="panel p-4" aria-label="Catalog verification funnel">
  <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-7">
    {items.map(([label, value]) => (
      <div>
        <div class="mono text-2xl font-semibold" style="color: var(--text);">{value}</div>
        <div class="text-sm" style="color: var(--secondary);">{label}</div>
      </div>
    ))}
  </div>
  <p class="mt-3 text-sm" style="color: var(--secondary);">{funnel.predicate_note}</p>
</section>
