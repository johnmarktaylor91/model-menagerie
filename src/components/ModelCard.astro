---
import type { ModelRecord } from "@/lib/catalog";

interface Props {
  model: ModelRecord;
}

const { model } = Astro.props;
const verified = model.forward_validated ? (model.input_tier === "real" ? "verified real" : "verified wrapper") : "not forward validated";
---

<article class="card overflow-hidden" data-model-card data-domain={model.domain} data-tier={model.input_tier} data-family={model.family_normalized} data-zoo={model.zoo} data-verified={String(model.forward_validated)}>
  <a href={`/models/${model.slug}`} class="block">
    <img src={model.assets.thumb.url} alt={`${model.display_name} architecture thumbnail`} loading="lazy" width="480" height="270" class="aspect-video w-full object-cover" />
    <div class="space-y-3 p-4">
      <div class="flex items-start justify-between gap-3">
        <h2 class="text-base font-semibold leading-tight">{model.display_name}</h2>
        <span class="chip mono shrink-0">{model.year ?? "year ?"}</span>
      </div>
      <div class="flex flex-wrap gap-2">
        <span class="chip">{model.family_normalized}</span>
        <span class="chip">{model.domain}</span>
        <span class="chip">{verified}</span>
      </div>
      <div class="flex items-center justify-between text-sm" style="color: var(--secondary);">
        <span>{model.zoo}</span>
        <span class="mono">{model.n_ops ?? "?"} ops</span>
      </div>
    </div>
  </a>
</article>
